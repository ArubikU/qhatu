# ─── Qhatu API — environment ──────────────────────────────────────────────────
# Copia a .env y rellena. NUNCA comitees el .env real.

# Database (PostgreSQL — Neon/Supabase/Railway)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# JWT (genera con: openssl rand -hex 48)
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
COOKIE_SECRET=""                      # opcional; cae a JWT_SECRET si vacío

# Hash de email (genera con: openssl rand -hex 32). NUNCA cambiar en prod (rompe logins)
EMAIL_HASH_SALT=""

# Email (Resend). Vacío = modo dev (OTP en consola)
RESEND_API_KEY=""
RESEND_FROM="Qhatu <noreply@tudominio.app>"
EMAIL_ASSET_BASE=""                   # base URL pública para el logo en correos

# Redis (Upstash). Vacío = sin streams/workers (SSE hace ping)
REDIS_URL=""

# Media storage (S3 / Backblaze B2 / R2 / MinIO). Vacío = subidas deshabilitadas
STORAGE_ENDPOINT=""
STORAGE_REGION="us-east-1"
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_PUBLIC_URL=""
STORAGE_FORCE_PATH_STYLE="true"
STORAGE_PRIVATE="true"
STORAGE_PRESIGN_EXPIRY="300"
STORAGE_READ_EXPIRY="3600"

# Web Push (VAPID). Genera: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:noreply@tudominio.app"

# Server
PORT=3002
FRONTEND_URL="https://tudominio.app"  # origen permitido por CORS + links de correo
NODE_ENV="production"
