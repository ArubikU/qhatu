    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.3",
    "@huggingface/transformers": "^4.2.0",
    "@prisma/client": "^5.22.0",
    "@qhatu/shared": "workspace:*",
    "bullmq": "^5.77.6",
    "crypto": "^1.0.1",
    "fastify": "^5.3.2",
    "ioredis": "^5.11.0",
    "node-cron": "^3.0.3",
    "resend": "^4.0.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
