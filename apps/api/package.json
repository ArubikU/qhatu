{
  "name": "@qhatu/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
