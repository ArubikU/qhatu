# ─── Qhatu Web — environment ──────────────────────────────────────────────────
# El front llama a /api/* y Next reescribe a API_URL (server-side).

# URL del API desplegado (Railway). En local: http://localhost:3002
API_URL="https://qhatu-api.up.railway.app"

# Vacío → el cliente usa el proxy /api (recomendado, cookies same-origin)
NEXT_PUBLIC_API_URL=""
